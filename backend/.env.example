PORT=5000
# Use mongodb+srv:// in most environments. On Windows, if you see querySrv ECONNREFUSED,
# switch to a direct mongodb:// URI for the Atlas primary shard (see Atlas Connect screen).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/expense-tracker
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
